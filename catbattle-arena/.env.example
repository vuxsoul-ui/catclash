NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional site URL for share cards and OG metadata
NEXT_PUBLIC_SITE_URL=https://catclash.org

# Optional TheCatAPI key for starter adoption image fetches
THECATAPI_API_KEY=
CAT_API_KEY=

# Figma integration
# Personal access token (never commit real token)
FIGMA_API_TOKEN=
# File key from https://www.figma.com/file/<FILE_KEY>/...
FIGMA_FILE_KEY=
# Optional comma-separated node ids for focused export
FIGMA_NODE_IDS=


# Seeding
SEED_OWNER_USER_ID=
SEED_NPC_MODE=false
ARE_YOU_SURE=false

# Optional: disable direct fallback if upstream image upload fails
# CATAAS_DIRECT_FALLBACK=0

# Egress controls
# 1 = reduce background refresh/polling on selected surfaces
NEXT_PUBLIC_LOW_EGRESS=1

# Use a separate project for local development to avoid burning production quota.
# Keep production values in your deployment environment only.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=YOUR_DEV_SERVICE_ROLE_KEY

# Launch controls (spike stacking)
FEATURE_LAUNCH_SPIKE_STACKING=true
FEATURE_HOT_MATCH_BIAS=true
FEATURE_SPOTLIGHT_ROTATION=true
LAUNCH_SPOTLIGHT_ROTATION_HOURS=8
FEATURE_RECRUIT_PUSH=true
FEATURE_CLUTCH_SHARE_PROMPT=true
FEATURE_SEED_MATCHUP_AUTOFILL=true
LAUNCH_LIMIT_GUEST_VOTES_PER_MINUTE=12
LAUNCH_LIMIT_GUEST_VOTES_PER_IP_PER_MINUTE=60
LAUNCH_RATE_LIMIT_SIGNUP_PER_IP_PER_HOUR=20
LAUNCH_QUALIFIED_DAILY_CAP_PER_INVITER=50
LAUNCH_GLOBAL_QUALIFIED_CAP=1000
